// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  image     String?  // Profile picture URL
  role      String   @default("CUSTOMER") // ADMIN, STORE_OWNER, CUSTOMER, DELIVERY_MAN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores         Store[]        @relation("StoreOwner")
  orders         Order[]        @relation("CustomerOrders")
  deliveryOrders Order[]        @relation("DeliveryManOrders")
  reviews        Review[]
}

model Store {
  id             String   @id @default(cuid())
  name           String
  description    String?
  image          String?  // Restaurant logo/profile image
  ownerId        String
  owner          User     @relation("StoreOwner", fields: [ownerId], references: [id])
  active         Boolean  @default(true)
  deliveryZone   String?
  deliveryCharge Float    @default(0)
  mainCategories String[] @default([]) // Burgers, Pizza, Sushi, Desserts, Coffee, Healthy
  latitude       Float?
  longitude      Float?
  address        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  categories Category[]
  products   Product[]
  orders     Order[]
  reviews    Review[]
  coupons    Coupon[]
}

model Category {
  id        String    @id @default(cuid())
  name      String
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id])
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String?
  price       Float
  image       String?     // Cloudflare R2 image URL
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  storeId     String
  store       Store       @relation(fields: [storeId], references: [id])
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}


model Order {
  id              String      @id @default(cuid())
  customerId      String
  customer        User        @relation("CustomerOrders", fields: [customerId], references: [id])
  storeId         String
  store           Store       @relation(fields: [storeId], references: [id])
  deliveryManId   String?
  deliveryMan     User?       @relation("DeliveryManOrders", fields: [deliveryManId], references: [id])
  status          String      @default("PENDING") // PENDING, ACCEPTED, PREPARING, OUT_FOR_DELIVERY, DELIVERED, CANCELLED
  totalPrice      Float
  discount        Float       @default(0)
  paymentMethod   String      @default("CASH") // CASH, CARD
  paymentStatus   String      @default("UNPAID") // UNPAID, PAID, FAILED, COD
  couponId        String?
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  deliveryAddress String
  deliveryLat     Float?
  deliveryLng     Float?
  deliveryCharge  Float       @default(0)
  items           OrderItem[]
  review          Review?
  paymentIntentId String?
  paymentIntent   PaymentIntent? @relation(fields: [paymentIntentId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float // Price at the time of order
}

model Review {
  id         String   @id @default(cuid())
  customerId String
  customer   User     @relation(fields: [customerId], references: [id])
  storeId    String
  store      Store    @relation(fields: [storeId], references: [id])
  orderId    String?  @unique
  order      Order?   @relation(fields: [orderId], references: [id])
  rating     Int
  comment    String?
  ownerReply String?
  createdAt  DateTime @default(now())
}

model Coupon {
  id         String   @id @default(cuid())
  code       String   @unique
  discount   Float // Percentage or Fixed amount
  type       String   @default("PERCENTAGE") // PERCENTAGE, FIXED
  storeId    String? // If null, it's a global coupon
  store      Store?   @relation(fields: [storeId], references: [id])
  expiryDate DateTime
  isActive   Boolean  @default(true)
  orders     Order[]
}

model PaymentIntent {
  id             String               @id @default(cuid())
  userId         String
  amount         Float
  currency       String               @default("BDT")
  status         String               @default("CREATED") // CREATED, PENDING, AUTHORIZED, CAPTURED, SETTLED, FAILED, REFUNDED, DISPUTED
  idempotencyKey String               @unique
  gatewayUrl     String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  
  transactions   PaymentTransaction[]
  orders         Order[]
}

model PaymentTransaction {
  id                  String         @id @default(cuid())
  intentId            String
  intent              PaymentIntent  @relation(fields: [intentId], references: [id])
  gateway             String         // SSLCOMMERZ, BKASH, etc.
  gatewayTxnId        String         @unique
  maskedCardLast4     String?
  cardBrand           String?
  status              String         // SUCCESS, FAILED, CANCELLED
  gatewayResponseCode String?
  rawPayloadEncrypted String?        // AES-256 encrypted response body
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  
  refunds             PaymentRefund[]
}

model PaymentRefund {
  id              String             @id @default(cuid())
  transactionId   String
  transaction     PaymentTransaction @relation(fields: [transactionId], references: [id])
  amount          Float
  status          String             // REQUESTED, SUCCEEDED, FAILED
  gatewayRefundId String?
  createdAt       DateTime           @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actor     String   // Email or User ID
  action    String   // PAYMENT_INTENT_CREATED, TRANSACTION_VERIFIED, etc.
  entity    String   // PaymentIntent, PaymentTransaction
  before    String?  // JSON string
  after     String?  // JSON string
  ip        String?
  timestamp DateTime @default(now())
}
